# ~/.zshrc.d/kavak.zsh — Kavak-specific environment
# Managed by chezmoi. Edit: companies/kavak/secrets.zsh.tmpl
# Deployed to: ~/.zshrc.d/kavak.zsh

# ── Artifactory ────────────────────────────────────────────────────────────────
export ARTIFACTORY_URL="https://kavak.jfrog.io/"
export ARTIFACTORY_USERNAME="{{ .artifactoryUser }}"

# Golang via Artifactory (token set lazily in ~/.secrets.zsh)
export GOPROXY="https://${ARTIFACTORY_USERNAME}:${ARTIFACTORY_ACCESS_TOKEN:-}@kavak.jfrog.io/artifactory/api/go/go"
export GONOSUMDB="gitlab.com/kavak-it/*"

# ── Kavak CLI ──────────────────────────────────────────────────────────────────
export PATH="$PATH:$HOME/.kavak/bin"

# ── Checks ─────────────────────────────────────────────────────────────────────
command -v vault >/dev/null || echo "⚠️  vault missing. brew tap hashicorp/tap && brew install hashicorp/tap/vault"
command -v glab  >/dev/null || echo "⚠️  glab missing. brew install glab"
