# ~/.zshrc.d/work-<slug>.zsh — Work company environment stub
# Reference: companies/example/secrets.zsh.tmpl
#
# Per-company shell stubs are generated by run_once_40 into ~/.zshrc.d/work-<slug>.zsh.
# To regenerate: chezmoi apply (after updating companies.toml)

# ── Private package registry ───────────────────────────────────────────────────
# Set WORK_REGISTRY_URL and WORK_REGISTRY_USER to match your company's registry.
# Token is loaded lazily from ~/.secrets.zsh (via 1Password).
export WORK_REGISTRY_URL="WORK_REGISTRY_URL_HERE"
export WORK_REGISTRY_USER="{{ .artifactoryUser }}"

# Example: Go proxy via private registry
# export GOPROXY="https://${WORK_REGISTRY_USER}:${WORK_REGISTRY_TOKEN:-}@your-company.example.com/go"
# export GONOSUMDB="gitlab.com/your-org/*"

# ── Company CLI / tooling ──────────────────────────────────────────────────────
# export PATH="$PATH:$HOME/.company-cli/bin"

# ── Checks ─────────────────────────────────────────────────────────────────────
# command -v your-tool >/dev/null || echo "⚠️  your-tool missing. brew install your-tool"
