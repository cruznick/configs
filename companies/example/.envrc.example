# .envrc.example — Per-company secrets template using direnv + 1Password CLI.
#
# Usage:
#   cp .envrc.example .envrc
#   # Edit .envrc — fill in your 1Password vault UUID and item names
#   direnv allow
#
# Secrets are fetched from 1Password on `cd` into this directory and
# unloaded automatically when you `cd` out. Requires:
#   - direnv installed (brew install direnv)
#   - 1Password CLI installed and signed in (op signin)

OP_VAULT="<vault-name-or-uuid>"   # e.g. "Personal" or vault UUID

if ! op whoami >/dev/null 2>&1; then
  echo "direnv: 1Password locked — run: op signin" >&2
else
  # ── Private package registry ───────────────────────────────────────────────
  # export WORK_REGISTRY_USER="$(op item get "<item>" --vault "$OP_VAULT" --fields username)"
  # export WORK_REGISTRY_TOKEN="$(op item get "<item>" --vault "$OP_VAULT" --fields credential --reveal)"

  # ── Secrets manager token ──────────────────────────────────────────────────
  # export VAULT_TOKEN="$(op item get "<item>" --vault "$OP_VAULT" --fields token --reveal)"

  # ── Derived env vars (non-secret, but depend on secrets above) ────────────
  # Go proxy via private registry:
  # export GOPROXY="https://${WORK_REGISTRY_USER}:${WORK_REGISTRY_TOKEN}@company.jfrog.io/go"
  # export GONOSUMDB="gitlab.com/your-org/*"

  # npm / pnpm registry:
  # export NPM_TOKEN="${WORK_REGISTRY_TOKEN}"
fi
