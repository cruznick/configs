# ~/.zshrc.d/work.zsh — Default work company environment stub
# Managed by chezmoi. Edit source: dot_zshrc.d/work.zsh.tmpl
#
# Per-company files (work-<slug>.zsh) are generated by chezmoi run_once_40
# and live alongside this file in ~/.zshrc.d/.
# All work-*.zsh files are sourced automatically by ~/.zshrc.
#
# Company-specific SECRETS (registry tokens, etc.) belong in direnv:
#   ~/repos/work/<platform>/<slug>/.envrc  (copy from .envrc.example, then: direnv allow)
# Global tokens (GITHUB_TOKEN) belong in ~/.secrets.zsh.

# ── Private package registry (non-secret parts) ───────────────────────────────
# Uncomment and fill in if your company uses a private registry.
# Registry token should come from direnv .envrc, not here.
# export WORK_REGISTRY_URL="https://your-company.example.com/registry"
# export WORK_REGISTRY_USER="{{ .artifactoryUser }}"
#
# Example: Go proxy — token fetched by direnv on cd into repo dir
# export GOPROXY="https://${WORK_REGISTRY_USER}:${WORK_REGISTRY_TOKEN:-}@company.example.com/go"
# export GONOSUMDB="gitlab.com/your-org/*"

# ── Company CLI / tooling path ─────────────────────────────────────────────────
# Uncomment if your company has a custom CLI binary directory:
# export PATH="$PATH:$HOME/.company-cli/bin"

# ── Tool checks ────────────────────────────────────────────────────────────────
# command -v your-tool >/dev/null || echo "⚠️  your-tool missing. brew install your-tool"
