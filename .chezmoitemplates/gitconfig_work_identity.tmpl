{{- /*
  Shared template for work git identity fragments.
  Usage: {{ template "gitconfig_work_identity" dict "slug" "kavak" "platform" "gl" "email" "user@company.com" "name" "Full Name" }}
*/ -}}
[user]
  name       = {{ .name | quote }}
  email      = {{ .email | quote }}
  signingkey = ~/.ssh/signing-pubs/work-{{ .platform }}.pub
