#!/usr/bin/env bash
# dots-brew-audit — Compare installed brew packages against the active Brewfile.
#
# Shows:
#   UNTRACKED  — installed on this machine but not in the active Brewfile (candidates to add)
#   MISSING    — in the active Brewfile but not installed (will install on next chezmoi apply)
#
# Usage: dots-brew-audit [--missing] [--json]
#   --missing   also show packages in the active Brewfile but not installed (default: hidden)
#   --json      emit machine-readable drift output
set -euo pipefail

SHOW_MISSING=0
OUTPUT_JSON=0

usage() {
  cat <<'EOF'
Usage: dots-brew-audit [--missing] [--json]
  --missing   also show packages in the active Brewfile but not installed
  --json      emit machine-readable drift output
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --missing)
      SHOW_MISSING=1
      ;;
    --json)
      OUTPUT_JSON=1
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
  shift
done

command -v brew >/dev/null 2>&1 || {
  echo "error: Homebrew not found" >&2
  exit 1
}

resolve_chezmoi_command() {
  if command -v chezmoi >/dev/null 2>&1; then
    command -v chezmoi
    return 0
  fi
  if [[ -x /opt/homebrew/bin/chezmoi ]]; then
    printf '%s\n' "/opt/homebrew/bin/chezmoi"
    return 0
  fi
  if [[ -x /usr/local/bin/chezmoi ]]; then
    printf '%s\n' "/usr/local/bin/chezmoi"
    return 0
  fi
  return 1
}

CHEZMOI_BIN="$(resolve_chezmoi_command || true)"
if [[ -z "$CHEZMOI_BIN" ]]; then
  echo "error: chezmoi not found" >&2
  exit 1
fi

source_dir() {
  local script_dir repo_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  repo_dir="$(cd "$script_dir/.." && pwd)"
  if [[ -f "$repo_dir/.chezmoitemplates/homebrew-active-brewfile.tmpl" ]]; then
    printf '%s\n' "$repo_dir"
    return 0
  fi
  "$CHEZMOI_BIN" source-path
}

BREWFILE="$(mktemp "${TMPDIR:-/tmp}/dotfiles-brew.XXXXXX")"
cleanup() {
  rm -f "$BREWFILE"
}
trap cleanup EXIT

if ! "$CHEZMOI_BIN" -S "$(source_dir)" execute-template '{{ includeTemplate ".chezmoitemplates/homebrew-active-brewfile.tmpl" . }}' >"$BREWFILE"; then
  echo "error: failed to render active Brewfile" >&2
  exit 1
fi

# ── Extract packages tracked in the active Brewfile ───────────────────────────
_extract_tracked() {
  local token
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    if [[ "$line" =~ ^[[:space:]]*(brew|cask)[[:space:]]+\"([^\"]+)\" ]]; then
      token="${BASH_REMATCH[2]}"
      token="${token##*/}"
      echo "$token"
      continue
    fi
  done < "$BREWFILE"
}

# ── Intentional exclusions (not tracked in Brewfiles by design) ───────────────
# These are managed by other tools or are intentionally manual.
declare -A EXCLUDED_REASON
EXCLUDED_REASON["chezmoi"]="installed by install.sh, not Brewfile"
EXCLUDED_REASON["terraform"]="managed by asdf (avoids shim conflicts)"
EXCLUDED_REASON["kubernetes-cli"]="managed by asdf (avoids shim conflicts)"
EXCLUDED_REASON["nvm"]="managed by asdf (use: asdf plugin add nodejs)"
EXCLUDED_REASON["pyenv"]="managed by asdf (use: asdf plugin add python)"
EXCLUDED_REASON["macfuse"]="manual install — https://osxfuse.github.io"
EXCLUDED_REASON["tcl-tk"]="keg-only build dep (Python/pyenv)"
EXCLUDED_REASON["tcl-tk@8"]="keg-only build dep (Python/pyenv)"
EXCLUDED_REASON["zlib"]="keg-only build dep"

# ── Get installed packages ────────────────────────────────────────────────────
INSTALLED_FORMULAE="$(brew list --formula --installed-on-request 2>/dev/null | sort)"
INSTALLED_CASKS="$(brew list --cask 2>/dev/null | sort)"
INSTALLED_ALL="$(printf '%s\n%s\n' "$INSTALLED_FORMULAE" "$INSTALLED_CASKS" | sort -u)"

TRACKED="$(_extract_tracked | sort -u)"

# ── Diff ──────────────────────────────────────────────────────────────────────
UNTRACKED="$(comm -23 <(echo "$INSTALLED_ALL") <(echo "$TRACKED"))"
MISSING="$(comm -13 <(echo "$INSTALLED_ALL") <(echo "$TRACKED"))"

REAL_UNTRACKED=""
INTENTIONAL=""
while IFS= read -r pkg; do
  [[ -z "$pkg" ]] && continue
  if [[ -n "${EXCLUDED_REASON[$pkg]+_}" ]]; then
    INTENTIONAL+="$pkg"$'\n'
  else
    REAL_UNTRACKED+="$pkg"$'\n'
  fi
done <<< "$UNTRACKED"

json_array() {
  printf '%s' "${1:-}" | jq -Rsc 'split("\n") | map(select(length > 0))'
}

if [[ $OUTPUT_JSON -eq 1 ]]; then
  jq -n \
    --argjson tracked "$(json_array "$TRACKED")" \
    --argjson untracked "$(json_array "$REAL_UNTRACKED")" \
    --argjson intentional "$(json_array "$INTENTIONAL")" \
    --argjson missing "$(json_array "$MISSING")" \
    '{
      tracked: $tracked,
      tracked_count: ($tracked | length),
      untracked: $untracked,
      untracked_count: ($untracked | length),
      intentional_untracked: $intentional,
      intentional_untracked_count: ($intentional | length),
      missing: $missing,
      missing_count: ($missing | length)
    }'
  exit 0
fi

# ── Output ────────────────────────────────────────────────────────────────────
BOLD=$'\033[1m'; YELLOW=$'\033[1;33m'; RED=$'\033[1;31m'; DIM=$'\033[2m'; RESET=$'\033[0m'

echo ""
echo "${BOLD}dots-brew-audit${RESET}"
echo "${DIM}Comparing: brew list --installed-on-request  vs  active rendered Brewfile${RESET}"
echo ""

if [[ -z "$UNTRACKED" ]]; then
  echo "✅ All explicitly installed packages are tracked in the active Brewfile."
else
  echo "${YELLOW}UNTRACKED${RESET} — installed on this machine, not in the active Brewfile:"
  echo "${DIM}(Review and add to the appropriate file under homebrew/Brewfile.*)${RESET}"
  echo ""
  if [[ -n "$REAL_UNTRACKED" ]]; then
    while IFS= read -r pkg; do
      [[ -z "$pkg" ]] && continue
      if echo "$INSTALLED_CASKS" | grep -qx "$pkg"; then
        printf "  %-40s %s\n" "$pkg" "${DIM}[cask]${RESET}"
      else
        printf "  %-40s %s\n" "$pkg" "${DIM}[formula]${RESET}"
      fi
    done <<< "$REAL_UNTRACKED"
  else
    echo "✅ All explicitly installed packages are tracked (or intentionally excluded)."
  fi

  if [[ -n "$INTENTIONAL" ]]; then
    echo ""
    echo "${DIM}Intentionally untracked:${RESET}"
    while IFS= read -r pkg; do
      [[ -z "$pkg" ]] && continue
      printf "  ${DIM}%-25s — %s${RESET}\n" "$pkg" "${EXCLUDED_REASON[$pkg]}"
    done <<< "$INTENTIONAL"
  fi
fi

if [[ $SHOW_MISSING -eq 1 ]]; then
  echo ""
  if [[ -z "$MISSING" ]]; then
    echo "✅ All tracked packages are installed."
  else
    echo "${RED}MISSING${RESET} — in the active Brewfile but not installed on this machine:"
    echo ""
    while IFS= read -r pkg; do
      [[ -z "$pkg" ]] && continue
      echo "  $pkg"
    done <<< "$MISSING"
  fi
fi

echo ""
