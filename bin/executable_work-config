#!/usr/bin/env bash
# work-config — On-demand work company configuration manager.
# Manages work company entries in companies.toml and creates the supporting
# directory structure and env templates.
#
# Usage:
#   work-config add   --slug=<slug> --platform=<gh|gl|both> --email=<email> [--key-prefix=<prefix>]
#   work-config remove --slug=<slug>
#   work-config list
#   work-config check  [--slug=<slug>]
set -euo pipefail

# ── Colours ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RESET='\033[0m'
ok()   { echo -e "  ${GREEN}✅${RESET} $*"; }
warn() { echo -e "  ${YELLOW}⚠️ ${RESET} $*"; }
err()  { echo -e "  ${RED}✗${RESET} $*" >&2; }
box()  { printf "║  %-52s║\n" "$*"; }

# ── Locate chezmoi source dir ──────────────────────────────────────────────────
CHEZMOI_SOURCE="$(chezmoi source-path 2>/dev/null)" || {
  echo "error: chezmoi not found or not initialised" >&2; exit 1
}
COMPANIES_TOML="$CHEZMOI_SOURCE/.chezmoidata/companies.toml"
ENVRC_EXAMPLE_SRC="$CHEZMOI_SOURCE/companies/example/.envrc.example"

# ── Helpers ────────────────────────────────────────────────────────────────────
validate_slug() {
  [[ "$1" =~ ^[a-z0-9][a-z0-9-]*$ ]] || {
    err "slug must be lowercase alphanumeric (hyphens ok, must start with letter/digit): $1"
    exit 1
  }
}

validate_email() {
  [[ "$1" =~ ^[^@]+@[^@]+\.[^@]+$ ]] || {
    err "invalid email: $1"; exit 1
  }
}

parse_platforms() {
  local raw="$1"
  case "$raw" in
    gh)   echo '["gh"]' ;;
    gl)   echo '["gl"]' ;;
    both) echo '["gl", "gh"]' ;;
    *)    err "platform must be gh, gl, or both"; exit 1 ;;
  esac
}

toml_platforms() {
  local raw="$1"
  case "$raw" in
    gh)   echo '"gh"' ;;
    gl)   echo '"gl"' ;;
    both) echo '"gl", "gh"' ;;
  esac
}

slug_in_toml() {
  grep -q "^\[companies\.${1}\]" "$COMPANIES_TOML" 2>/dev/null
}

# ── CMD: add ──────────────────────────────────────────────────────────────────
cmd_add() {
  local slug="" email="" platform="" key_prefix=""
  for arg in "$@"; do
    case "$arg" in
      --slug=*)       slug="${arg#*=}" ;;
      --email=*)      email="${arg#*=}" ;;
      --platform=*)   platform="${arg#*=}" ;;
      --key-prefix=*) key_prefix="${arg#*=}" ;;
      *) err "unknown argument: $arg"; exit 1 ;;
    esac
  done

  [[ -n "$slug" ]]     || { err "--slug is required"; exit 1; }
  [[ -n "$email" ]]    || { err "--email is required"; exit 1; }
  [[ -n "$platform" ]] || { err "--platform is required (gh|gl|both)"; exit 1; }
  validate_slug "$slug"
  validate_email "$email"

  key_prefix="${key_prefix:-$slug}"
  local platforms_toml
  platforms_toml="$(toml_platforms "$platform")"

  echo ""
  echo "╔══════════════════════════════════════════════════════╗"
  echo "║  work-config add — ${slug}$(printf '%*s' $((36 - ${#slug})) '')║"
  echo "╠══════════════════════════════════════════════════════╣"

  # 1. Update companies.toml
  if slug_in_toml "$slug"; then
    warn "companies.toml already has [companies.$slug] — skipping entry"
  else
    [[ -f "$COMPANIES_TOML" ]] || { mkdir -p "$(dirname "$COMPANIES_TOML")"; touch "$COMPANIES_TOML"; }
    cat >> "$COMPANIES_TOML" <<TOML

[companies.${slug}]
  slug           = "${slug}"
  email          = "${email}"
  platforms      = [${platforms_toml}]
  ssh_key_prefix = "${key_prefix}"
TOML
    ok "companies.toml updated: [companies.${slug}] added"
  fi

  # 2. Create repo directories
  local dirs_created=()
  case "$platform" in
    gh|both)
      mkdir -p "$HOME/repos/work/gh/$slug"
      dirs_created+=("~/repos/work/gh/$slug/")
      ok "~/repos/work/gh/$slug/ created"
      ;;
  esac
  case "$platform" in
    gl|both)
      mkdir -p "$HOME/repos/work/gl/$slug"
      dirs_created+=("~/repos/work/gl/$slug/")
      ok "~/repos/work/gl/$slug/ created"
      ;;
  esac

  # 3. Copy .envrc.example to repo dir(s)
  if [[ -f "$ENVRC_EXAMPLE_SRC" ]]; then
    case "$platform" in
      gh|both)
        cp "$ENVRC_EXAMPLE_SRC" "$HOME/repos/work/gh/$slug/.envrc.example"
        ok "~/repos/work/gh/$slug/.envrc.example created"
        ;;
    esac
    case "$platform" in
      gl|both)
        cp "$ENVRC_EXAMPLE_SRC" "$HOME/repos/work/gl/$slug/.envrc.example"
        ok "~/repos/work/gl/$slug/.envrc.example created"
        ;;
    esac
  else
    warn ".envrc.example template not found at $ENVRC_EXAMPLE_SRC"
  fi

  # 4. Run chezmoi apply
  echo "  Running chezmoi apply..."
  if chezmoi apply 2>&1 | sed 's/^/    /'; then
    ok "chezmoi apply completed"
  else
    warn "chezmoi apply returned non-zero — check output above"
  fi

  # 5. Summary + next steps
  echo "╠══════════════════════════════════════════════════════╣"
  echo "║  ⚡ Next steps (manual):                              ║"
  box "1. Create SSH key(s) in 1Password:"
  case "$platform" in
    gh|gl)
      box "     op item create --category ssh \\"
      box "       --title \"ssh-sign-${key_prefix}-${platform}\""
      ;;
    both)
      box "     op item create --category ssh \\"
      box "       --title \"ssh-sign-${key_prefix}-gh\""
      box "     op item create --category ssh \\"
      box "       --title \"ssh-sign-${key_prefix}-gl\""
      ;;
  esac
  box "2. Run: chezmoi apply  (to export pubkeys)"
  case "$platform" in
    gh)
      box "3. Add ~/.ssh/signing-pubs/${key_prefix}-gh.pub to GitHub"
      box "4. Edit ~/repos/work/gh/${slug}/.envrc.example"
      ;;
    gl)
      box "3. Add ~/.ssh/signing-pubs/${key_prefix}-gl.pub to GitLab"
      box "4. Edit ~/repos/work/gl/${slug}/.envrc.example"
      ;;
    both)
      box "3. Add ~/.ssh/signing-pubs/${key_prefix}-gh.pub to GitHub"
      box "   Add ~/.ssh/signing-pubs/${key_prefix}-gl.pub to GitLab"
      box "4. Edit ~/repos/work/gh/${slug}/.envrc.example"
      box "   Edit ~/repos/work/gl/${slug}/.envrc.example"
      ;;
  esac
  box "     → copy to .envrc and fill in op:// references"
  box "     → run: direnv allow"
  box ""
  box "Note: Update sha256 hash in .envrc.example after first"
  box "      direnv allow (direnv will print the correct hash)"
  echo "╚══════════════════════════════════════════════════════╝"
  echo ""
}

# ── CMD: remove ───────────────────────────────────────────────────────────────
cmd_remove() {
  local slug=""
  for arg in "$@"; do
    case "$arg" in
      --slug=*) slug="${arg#*=}" ;;
      *) err "unknown argument: $arg"; exit 1 ;;
    esac
  done
  [[ -n "$slug" ]] || { err "--slug is required"; exit 1; }

  if ! slug_in_toml "$slug"; then
    err "[companies.$slug] not found in $COMPANIES_TOML"
    exit 1
  fi

  echo ""
  echo "Removing [companies.$slug] from companies.toml..."
  # Remove the block: from [companies.<slug>] to the next [companies. or EOF
  # Use a Python one-liner for reliable TOML section removal
  python3 - "$COMPANIES_TOML" "$slug" <<'PYEOF'
import sys, re
path, slug = sys.argv[1], sys.argv[2]
with open(path) as f:
    content = f.read()
# Remove section from [companies.<slug>] to next [companies. header or EOF
pattern = rf'\n\[companies\.{re.escape(slug)}\][^\[]*'
new = re.sub(pattern, '', content)
with open(path, 'w') as f:
    f.write(new)
print(f"  Removed [companies.{slug}]")
PYEOF

  echo "  Running chezmoi apply..."
  chezmoi apply

  echo ""
  echo "✅ [companies.$slug] removed. Manual cleanup:"
  echo "  - rm -rf ~/repos/work/gh/$slug ~/repos/work/gl/$slug"
  echo "  - rm -f ~/.gitconfig-work-$slug-{gh,gl}"
  echo "  - Remove SSH key entries from 1Password if no longer needed"
  echo ""
}

# ── CMD: list ─────────────────────────────────────────────────────────────────
cmd_list() {
  echo ""
  echo "Companies configured:"
  if ! grep -q "^\[companies\." "$COMPANIES_TOML" 2>/dev/null; then
    echo "  (none — add with: work-config add --slug=acme --platform=gh --email=you@acme.com)"
    echo ""
    return
  fi

  # Parse and display each company
  python3 - "$COMPANIES_TOML" <<'PYEOF'
import sys
try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        sys.exit("error: Python tomllib not available. Install tomli: pip install tomli  (or upgrade to Python 3.11+)")

with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)

companies = data.get("companies", {})
if not companies:
    print("  (none)")
    sys.exit(0)

for slug, co in companies.items():
    email    = co.get("email", "(no email)")
    platforms = ", ".join(co.get("platforms", []))
    prefix   = co.get("ssh_key_prefix", slug)
    print(f"  {slug:<12} email: {email:<30} platforms: {platforms:<8} key-prefix: {prefix}")
PYEOF

  echo ""
  echo "Repo dirs:"
  python3 - "$COMPANIES_TOML" <<'PYEOF'
import sys, os
try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        sys.exit("error: Python tomllib not available. Install tomli: pip install tomli  (or upgrade to Python 3.11+)")

home = os.path.expanduser("~")
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)

for slug, co in data.get("companies", {}).items():
    for p in co.get("platforms", []):
        path = os.path.join(home, "repos", "work", p, slug)
        exists = "✅ exists" if os.path.isdir(path) else "❌ missing"
        print(f"  ~/repos/work/{p}/{slug}/  {exists}")
PYEOF

  echo ""
  echo "Git configs:"
  python3 - "$COMPANIES_TOML" <<'PYEOF'
import sys, os
try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        sys.exit("error: Python tomllib not available. Install tomli: pip install tomli  (or upgrade to Python 3.11+)")

home = os.path.expanduser("~")
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)

for slug, co in data.get("companies", {}).items():
    for p in co.get("platforms", []):
        path = os.path.join(home, f".gitconfig-work-{slug}-{p}")
        exists = "✅ exists" if os.path.isfile(path) else "❌ missing (run: chezmoi apply)"
        print(f"  ~/.gitconfig-work-{slug}-{p}  {exists}")
PYEOF

  echo ""
  echo "SSH pubkeys:"
  python3 - "$COMPANIES_TOML" <<'PYEOF'
import sys, os
try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        sys.exit("error: Python tomllib not available. Install tomli: pip install tomli  (or upgrade to Python 3.11+)")

home = os.path.expanduser("~")
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)

for slug, co in data.get("companies", {}).items():
    prefix = co.get("ssh_key_prefix", slug)
    for p in co.get("platforms", []):
        path = os.path.join(home, ".ssh", "signing-pubs", f"{prefix}-{p}.pub")
        exists = "✅ exists" if os.path.isfile(path) else "❌ missing (run: chezmoi apply after creating 1P key)"
        print(f"  ~/.ssh/signing-pubs/{prefix}-{p}.pub  {exists}")
PYEOF
  echo ""
}

# ── CMD: check ────────────────────────────────────────────────────────────────
cmd_check() {
  local filter_slug=""
  for arg in "$@"; do
    case "$arg" in
      --slug=*) filter_slug="${arg#*=}" ;;
      *) err "unknown argument: $arg"; exit 1 ;;
    esac
  done

  cmd_list

  # Verify ~/.gitconfig has no unrendered template vars
  echo "Checking for unrendered template vars in ~/.gitconfig..."
  if grep -q '{{' "$HOME/.gitconfig" 2>/dev/null; then
    warn "~/.gitconfig contains '{{' — chezmoi may not have been applied. Run: chezmoi apply"
  else
    ok "~/.gitconfig has no unrendered template vars"
  fi
  echo ""

  # Run git-check in each company repo dir
  if ! grep -q "^\[companies\." "$COMPANIES_TOML" 2>/dev/null; then
    return
  fi

  echo "Git identity verification:"
  python3 - "$COMPANIES_TOML" "$filter_slug" <<'PYEOF'
import sys, os, subprocess
try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        sys.exit("error: Python tomllib not available. Install tomli: pip install tomli  (or upgrade to Python 3.11+)")

home = os.path.expanduser("~")
with open(sys.argv[1], "rb") as f:
    data = tomllib.load(f)

filter_slug = sys.argv[2] if len(sys.argv) > 2 else ""

for slug, co in data.get("companies", {}).items():
    if filter_slug and slug != filter_slug:
        continue
    for p in co.get("platforms", []):
        repo_dir = os.path.join(home, "repos", "work", p, slug)
        expected_email = co.get("email", "")
        print(f"\n  [{slug} / {p}]  {repo_dir}")
        if not os.path.isdir(repo_dir):
            print(f"    ❌ dir not found — create with: mkdir -p {repo_dir}")
            continue
        # Check if it's a git repo (any subdirectory will do for includeIf matching)
        try:
            result = subprocess.run(
                ["git", "config", "user.email"],
                cwd=repo_dir, capture_output=True, text=True
            )
            actual_email = result.stdout.strip()
            if actual_email == expected_email:
                print(f"    ✅ user.email: {actual_email}")
            elif actual_email:
                print(f"    ⚠️  user.email: {actual_email}  (expected: {expected_email})")
            else:
                print(f"    ❌ user.email not set — gitconfig includeIf may not match (need a git repo in this dir)")
            result2 = subprocess.run(
                ["git", "config", "--show-origin", "user.signingkey"],
                cwd=repo_dir, capture_output=True, text=True
            )
            if result2.returncode == 0:
                print(f"    ✅ signingkey: {result2.stdout.strip()}")
            else:
                print(f"    ❌ signingkey not set")
        except Exception as e:
            print(f"    ❌ error: {e}")
PYEOF
  echo ""
}

# ── Dispatch ───────────────────────────────────────────────────────────────────
CMD="${1:-}"
shift || true

case "$CMD" in
  add)    cmd_add    "$@" ;;
  remove) cmd_remove "$@" ;;
  list)   cmd_list   "$@" ;;
  check)  cmd_check  "$@" ;;
  ""|--help|-h)
    echo "Usage: work-config <command> [options]"
    echo ""
    echo "Commands:"
    echo "  add     --slug=<slug> --platform=<gh|gl|both> --email=<email> [--key-prefix=<prefix>]"
    echo "  remove  --slug=<slug>"
    echo "  list"
    echo "  check   [--slug=<slug>]"
    ;;
  *)
    err "unknown command: $CMD"
    echo "Run 'work-config --help' for usage"
    exit 1
    ;;
esac
