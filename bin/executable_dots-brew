#!/usr/bin/env bash
# dots-brew — Render and apply the active Homebrew Brewfile groups.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  dots-brew render [--stdout]
  dots-brew sync
  dots-brew update
  dots-brew plan
  dots-brew cleanup [--force]
  dots-brew status
  dots-brew audit [--missing]
  dots-brew groups

Commands:
  render   write the active Brewfile to stdout
  sync     install the active Brewfile with brew bundle
  update   brew update && brew upgrade && sync declared Brewfiles
  plan     dry-run the install/upgrade work sync would perform
  cleanup  explicitly uninstall undeclared Homebrew packages from the active Brewfile
  status   show active groups and current drift summary
  audit    compare installed packages against the active Brewfile
  groups   show repo-tracked Brewfile groups and local enablement
EOF
}

require_brew() {
  command -v brew >/dev/null 2>&1 || {
    echo "Homebrew not found" >&2
    exit 1
  }
}

resolve_chezmoi_command() {
  if command -v chezmoi >/dev/null 2>&1; then
    command -v chezmoi
    return 0
  fi
  if [[ -x /opt/homebrew/bin/chezmoi ]]; then
    printf '%s\n' "/opt/homebrew/bin/chezmoi"
    return 0
  fi
  if [[ -x /usr/local/bin/chezmoi ]]; then
    printf '%s\n' "/usr/local/bin/chezmoi"
    return 0
  fi
  return 1
}

CHEZMOI_BIN="$(resolve_chezmoi_command || true)"
if [[ -z "$CHEZMOI_BIN" ]]; then
  echo "chezmoi not found" >&2
  exit 1
fi

source_dir() {
  local script_dir repo_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  repo_dir="$(cd "$script_dir/.." && pwd)"
  if [[ -f "$repo_dir/.chezmoitemplates/homebrew-active-brewfile.tmpl" ]]; then
    printf '%s\n' "$repo_dir"
    return 0
  fi
  "$CHEZMOI_BIN" source-path
}

audit_command() {
  local script_dir candidate
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  candidate="$script_dir/executable_dots-brew-audit"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi
  printf '%s\n' "dots-brew-audit"
}

render_brewfile() {
  "$CHEZMOI_BIN" -S "$(source_dir)" execute-template '{{ includeTemplate ".chezmoitemplates/homebrew-active-brewfile.tmpl" . }}'
}

with_brewfile() {
  local tmp
  tmp="$(mktemp "${TMPDIR:-/tmp}/dotfiles-brew.XXXXXX")"
  trap 'rm -f "$tmp"' RETURN
  render_brewfile >"$tmp"
  "$@" "$tmp"
}

plan_with_brewfile() {
  local file="$1"
  echo "dots-brew plan"
  echo ""
  echo "Active groups:"
  "$0" groups
  echo ""
  echo "Planned sync command:"
  echo "  brew bundle install --file=$file"
  echo "Cleanup is not part of sync."
  echo "Use: dots-brew cleanup"
  echo ""
  if brew bundle check --verbose --file "$file"; then
    echo "No installs or upgrades are needed."
  else
    echo ""
    echo "Changes are needed to match the active Brewfile."
    echo "Use: dots-brew sync"
  fi
}

status_report() {
  local audit_json
  echo "dots-brew status"
  echo ""
  echo "Active groups:"
  "$0" groups
  if ! command -v brew >/dev/null 2>&1; then
    echo ""
    echo "Drift summary:"
    echo "  brew not installed; drift checks unavailable"
    return 0
  fi

  audit_json="$("$(audit_command)" --json)"
  echo ""
  echo "Drift summary:"
  echo "  missing: $(printf '%s' "$audit_json" | jq -r '.missing_count')"
  echo "  untracked: $(printf '%s' "$audit_json" | jq -r '.untracked_count')"
  echo "  intentionally untracked: $(printf '%s' "$audit_json" | jq -r '.intentional_untracked_count')"
  echo ""
  echo "Details:"
  echo "  audit: dots-brew audit"
  echo "  install drift only: dots-brew audit --missing"
  echo "  destructive cleanup: dots-brew cleanup"
}

cleanup_with_brewfile() {
  local file="$1"
  local force="${2:-false}"
  local reply=""

  echo "dots-brew cleanup"
  echo ""
  echo "This will uninstall Homebrew formulae and casks not declared in the active Brewfile."
  echo "It is intentionally not run by chezmoi apply, bootstrap, or dots-brew sync."
  echo ""
  echo "Preview:"
  if brew bundle cleanup --file "$file"; then
    echo "No undeclared packages would be removed."
    return 0
  fi

  if [[ "$force" != "true" ]]; then
    echo ""
    printf "Proceed with uninstall? [y/N]: "
    read -r reply
    case "$reply" in
      y|Y|yes|YES)
        ;;
      *)
        echo "Cancelled."
        return 0
        ;;
    esac
  fi

  brew bundle cleanup --force --file "$file"
}

cmd="${1:-}"
case "$cmd" in
  render)
    render_brewfile
    ;;
  sync)
    require_brew
    with_brewfile brew bundle install --file
    ;;
  update)
    require_brew
    brew update
    brew upgrade
    with_brewfile brew bundle install --file
    ;;
  plan)
    require_brew
    with_brewfile plan_with_brewfile
    ;;
  cleanup)
    require_brew
    shift || true
    case "${1:-}" in
      "")
        with_brewfile cleanup_with_brewfile
        ;;
      --force)
        with_brewfile cleanup_with_brewfile true
        ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
    ;;
  status)
    status_report
    ;;
  audit)
    shift || true
    exec "$(audit_command)" "$@"
    ;;
  groups)
    "$CHEZMOI_BIN" -S "$(source_dir)" execute-template '{{ includeTemplate ".chezmoitemplates/effective-config.json.tmpl" . }}' \
      | jq -r '
          .optional_integrations as $o
          | [
              ["core", (if $o | has("homebrew_core") then $o.homebrew_core else true end)],
              ["dev", (if $o | has("homebrew_dev") then $o.homebrew_dev else true end)],
              ["apps", (if $o | has("homebrew_apps") then $o.homebrew_apps else true end)],
              ["extras", (if $o | has("homebrew_extras") then $o.homebrew_extras else false end)],
              ["work", (if $o | has("homebrew_work") then $o.homebrew_work else false end)]
            ][]
          | "\(.[0])\t\((.[1]) | if . then "enabled" else "disabled" end)\thomebrew/Brewfile.\(.[0])"
        '
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
