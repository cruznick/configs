# =============================================================================
# Benjamin's .zshrc — managed by chezmoi
# Edit source: ~/repos/personal/gh/configs/dot_zshrc.tmpl
# Apply changes: chezmoi apply
# =============================================================================

# =============================================================================
# BASIC ENV
# =============================================================================
export EDITOR="code"
export VISUAL="code"

# Detect OS
if [[ "$OSTYPE" == "darwin"* ]]; then
  export OS=macos
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
  export OS=linux
else
  export OS=unknown
fi

# =============================================================================
# PATH
# =============================================================================
path_prepend() { [[ ":$PATH:" != *":$1:"* ]] && export PATH="$1:$PATH"; }
path_append()  { [[ ":$PATH:" != *":$1:"* ]] && export PATH="$PATH:$1"; }

path_prepend "/opt/homebrew/bin"
path_prepend "/opt/homebrew/opt/git/bin"
path_append  "$HOME/bin"
path_append  "$HOME/Library/pnpm"

# =============================================================================
# HOMEBREW (macOS)
# =============================================================================
if [[ -f "/opt/homebrew/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# =============================================================================
# ZINIT
# =============================================================================
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
source "${ZINIT_HOME}/zinit.zsh"

zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab

zinit snippet OMZL::git.zsh
zinit snippet OMZP::git
zinit snippet OMZP::sudo
zinit snippet OMZP::vscode
zinit snippet OMZP::aws
zinit snippet OMZP::kubectl
zinit snippet OMZP::kubectx
zinit snippet OMZP::docker
zinit snippet OMZP::colored-man-pages
zinit snippet OMZP::command-not-found

autoload -Uz compinit && compinit
zinit cdreplay -q

# =============================================================================
# PROMPT
# =============================================================================
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
command -v starship >/dev/null && eval "$(starship init zsh)"

# =============================================================================
# KEYBINDINGS
# =============================================================================
bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[w' kill-region

# Fix Home/End keys
if (( ${+terminfo[khome]} )); then bindkey "${terminfo[khome]}" beginning-of-line; fi
if (( ${+terminfo[kend]}  )); then bindkey "${terminfo[kend]}"  end-of-line;       fi
bindkey '^[[H' beginning-of-line
bindkey '^[[F' end-of-line

# =============================================================================
# HISTORY
# =============================================================================
HISTSIZE=50000
SAVEHIST=$HISTSIZE
HISTFILE=~/.zsh_history

setopt appendhistory sharehistory hist_ignore_space hist_ignore_all_dups \
       hist_save_no_dups hist_ignore_dups hist_find_no_dups

# =============================================================================
# OPTS
# =============================================================================
setopt auto_cd auto_name_dirs auto_pushd pushd_ignore_dups

# =============================================================================
# COMPLETION STYLING
# =============================================================================
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' menu no

# =============================================================================
# ALIASES — better defaults
# =============================================================================
if command -v eza >/dev/null; then
  alias ls='eza --group-directories-first --git'
  alias ll='eza -lah --group-directories-first --git'
else
  alias ls='ls -G'
  alias ll='ls -lahG'
fi

alias vim='nvim'
alias c='clear'

# DevOps shortcuts
alias k='kubectl'
alias kgp='kubectl get pods'
alias kgs='kubectl get svc'
alias kgn='kubectl get nodes'
alias kctx='kubectx'
alias kns='kubens'
alias tf='terraform'
alias pu='pulumi'
alias g='git'
alias awswho='aws sts get-caller-identity'

# Colima
alias col='colima'
alias colstart='colima start'
alias colstop='colima stop'
alias cold='colima delete'

# AI CLIs
alias cc='claude'
alias cx='codex'

# Dotfiles
alias dots-apply='chezmoi apply'
alias dots-update='chezmoi update'
alias dots-diff='chezmoi diff'
alias dots-edit='chezmoi edit'
# dots-capture-rect: sync Rectangle Pro shortcuts from THIS machine → repo
# dots-capture-istat: sync iStat Menus config from THIS machine → repo (primary machine only)
# dots-capture: sync both (primary machine only)
alias dots-capture-rect='chezmoi add ~/Library/Preferences/com.knollsoft.Hookshot.plist'
alias dots-capture-istat='chezmoi add \
  ~/Library/Preferences/com.bjango.istatmenus.plist \
  ~/Library/Preferences/com.bjango.istatmenus.menubar.7.plist \
  ~/Library/Preferences/com.bjango.istatmenus.agent.plist \
  ~/Library/Preferences/com.bjango.istatmenus.status.plist'
alias dots-capture='dots-capture-rect && dots-capture-istat'
alias dots-allow='direnv allow'

# =============================================================================
# FZF
# =============================================================================
command -v fzf >/dev/null && eval "$(fzf --zsh)"

if command -v eza >/dev/null; then
  zstyle ':fzf-tab:complete:cd:*'          fzf-preview 'eza -lah --git $realpath'
  zstyle ':fzf-tab:complete:__zoxide_z:*'  fzf-preview 'eza -lah --git $realpath'
else
  zstyle ':fzf-tab:complete:cd:*'          fzf-preview 'ls -lahG $realpath'
  zstyle ':fzf-tab:complete:__zoxide_z:*'  fzf-preview 'ls -lahG $realpath'
fi

# =============================================================================
# ZOXIDE
# =============================================================================
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

# =============================================================================
# NAVIGATION
# =============================================================================
cd() {
  case "$*" in
    "...")    [ -d ../.. ]       && builtin cd ../.. ;;
    "....")   [ -d ../../.. ]    && builtin cd ../../.. ;;
    ".....")  [ -d ../../../.. ] && builtin cd ../../../.. ;;
    *)        builtin cd "$@" ;;
  esac
}
mcd() { mkdir -p "$1" && cd "$1"; }
alias md='mkdir -p'
alias rd='rmdir'
alias d='dirs -v'

# =============================================================================
# ASDF (version manager — terraform, kubectl, nodejs, python, golang managed here)
# =============================================================================
for _asdf_init in \
  "/opt/homebrew/opt/asdf/libexec/asdf.sh" \
  "/usr/local/opt/asdf/libexec/asdf.sh" \
  "$HOME/.asdf/asdf.sh"; do
  [[ -f "$_asdf_init" ]] && source "$_asdf_init" && break
done
unset _asdf_init
export ASDF_DATA_DIR="${ASDF_DATA_DIR:-$HOME/.asdf}"

# =============================================================================
# NODE / PNPM
# =============================================================================
export PNPM_HOME="$HOME/Library/pnpm"

# =============================================================================
# GO
# =============================================================================
[[ -s "$HOME/.gvm/scripts/gvm" ]] && source "$HOME/.gvm/scripts/gvm"

# =============================================================================
# UV — Python package/venv manager (project-level)
# Global python version managed by asdf; uv manages venvs within projects.
# =============================================================================
command -v uv >/dev/null && eval "$(uv generate-shell-completion zsh)" 2>/dev/null || true

# =============================================================================
# 1PASSWORD SSH AGENT
# =============================================================================
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# Auto op signin when entering a directory with an op://-backed .envrc
if command -v op >/dev/null; then
  _auto_op_signin() {
    local envrc="$PWD/.envrc"
    if [[ -f "$envrc" ]] && grep -ql 'op://' "$envrc" 2>/dev/null; then
      op whoami &>/dev/null || eval "$(op signin --account {{ .personalEmail }})" 2>/dev/null || true
    fi
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook chpwd _auto_op_signin
fi

# =============================================================================
# GLAB helpers
# =============================================================================
# GLAB_CONFIG_DIR is set per-company by ~/.zshrc.d/work-<slug>.zsh
# Personal glab uses a dedicated config dir
glab-personal() {
  GLAB_CONFIG_DIR="$HOME/.config/glab-personal" glab "$@"
}

# =============================================================================
# COMPANY CONFIG
# Sources ~/.zshrc.d/work-<slug>.zsh per company (non-secret config)
# Generated by chezmoi run_once_40. Company secrets → direnv .envrc per repo dir.
# =============================================================================
for _rc in "$HOME/.zshrc.d/work-"*.zsh(N); do
  source "$_rc"
done
unset _rc

[[ -f "$HOME/.zshrc.d/personal.zsh" ]] && source "$HOME/.zshrc.d/personal.zsh"

# =============================================================================
# DIRENV (per-directory env loading — fetches company secrets from 1Password on cd)
# =============================================================================
command -v direnv >/dev/null && eval "$(direnv hook zsh)"

