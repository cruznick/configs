# 1Password SSH agent — managed by chezmoi
# Edit source: dot_config/1Password/ssh/agent.toml.tmpl

# Personal keys
[[ssh-keys]]
vault = "{{ .op1pVault }}"
item  = "ssh-sign-personal-gl"

[[ssh-keys]]
vault = "{{ .op1pVault }}"
item  = "ssh-sign-personal-gh"

# Work keys — one entry per company × platform
# (populated via chezmoi when companies are added to .chezmoidata/companies.toml)
{{- range $slug, $co := default (dict) .companies }}
{{- range $co.platforms }}

[[ssh-keys]]
vault = "{{ $.op1pVault }}"
item  = "ssh-sign-{{ default $slug $co.ssh_key_prefix }}-{{ . }}"
{{- end }}
{{- end }}
