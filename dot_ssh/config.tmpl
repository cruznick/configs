# Managed by chezmoi — edit source: dot_ssh/config.tmpl

# Colima (container runtime) — keep first
{{ if stat (joinPath .chezmoi.homeDir ".colima" "ssh_config") -}}
Include {{ .chezmoi.homeDir }}/.colima/ssh_config
{{ end -}}

# ── 1Password SSH agent (all hosts) ──────────────────────────────────────────
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# ── Personal identities ───────────────────────────────────────────────────────
Host github.com-personal
  HostName github.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/signing-pubs/personal-gh.pub

Host gitlab.com-personal
  HostName gitlab.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/signing-pubs/personal-gl.pub

# ── Work identities — generated per company ──────────────────────────────────
{{ range $slug, $co := default (dict) .companies -}}
{{ if has "gh" $co.platforms }}
Host github.com-{{ $slug }}
  HostName github.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/signing-pubs/{{ default $slug $co.ssh_key_prefix }}-gh.pub
{{ end -}}
{{ if has "gl" $co.platforms }}
Host gitlab.com-{{ $slug }}
  HostName gitlab.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/signing-pubs/{{ default $slug $co.ssh_key_prefix }}-gl.pub
{{ end -}}
{{ end -}}
