{{- $cfg := includeTemplate ".chezmoitemplates/effective-config.json.tmpl" . | fromJson -}}
{{- $identity := $cfg.identity | default dict -}}
{{- $opSock := joinPath .chezmoi.homeDir "Library" "Group Containers" "2BUA8C4S2C.com.1password" "t" "agent.sock" -}}
# Managed by chezmoi — edit source: dot_ssh/config.tmpl

# Colima (container runtime) — keep first
{{ if stat (joinPath .chezmoi.homeDir ".colima" "ssh_config") -}}
Include {{ .chezmoi.homeDir }}/.colima/ssh_config
{{ end -}}

# ── 1Password SSH agent (all hosts) ──────────────────────────────────────────
{{- if and ((index ($cfg.optional_integrations | default dict) "onepassword") | default true) (stat $opSock) }}
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{ end }}

# ── Personal identities ───────────────────────────────────────────────────────
Host github.com-personal
  HostName github.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/signing-pubs/personal-gh.pub

Host gitlab.com-personal
  HostName gitlab.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/signing-pubs/personal-gl.pub

# ── Local work identities for Git access ─────────────────────────────────────
{{ range $slug := ($cfg.selected_work_contexts | default list) -}}
{{ $ctx := index ($cfg.work_contexts | default dict) $slug | default dict -}}
{{ $providers := index ((index $ctx "providers") | default dict) "enabled" | default list -}}
{{ $ssh := (index $ctx "ssh") | default dict -}}
{{ if has "gh" $providers }}
Host {{ (index $ssh "github_alias") | default (printf "github.com-%s" $slug) }}
  HostName github.com
  User git
  IdentitiesOnly yes
{{- if (index $ssh "github_identity_file") }}
  IdentityFile {{ index $ssh "github_identity_file" }}
{{- end }}
{{ end -}}
{{ if has "gl" $providers }}
Host {{ (index $ssh "gitlab_alias") | default (printf "gitlab.com-%s" $slug) }}
  HostName gitlab.com
  User git
  IdentitiesOnly yes
{{- if (index $ssh "gitlab_identity_file") }}
  IdentityFile {{ index $ssh "gitlab_identity_file" }}
{{- end }}
{{ end -}}
{{ end -}}
