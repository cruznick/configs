#!/usr/bin/env bash
# run_onchange_10-install-brew.sh — Install Homebrew packages from grouped Brewfiles
# Re-runs automatically whenever this file or any tracked Brewfile group changes.
set -euo pipefail
{{ $cfg := includeTemplate ".chezmoitemplates/effective-config.json.tmpl" . | fromJson }}
{{ $optional := $cfg.optional_integrations | default dict }}
{{ $homebrewCoreEnabled := true }}
{{ if hasKey $optional "homebrew_core" }}
{{ $homebrewCoreEnabled = index $optional "homebrew_core" }}
{{ end }}
{{ $brewfile := includeTemplate ".chezmoitemplates/homebrew-active-brewfile.tmpl" . }}

{{ if ne .chezmoi.os "darwin" -}}
echo "Skipping brew install: not macOS"
exit 0
{{ end -}}

log() { printf "\n\033[1;34m==> %s\033[0m\n" "$*"; }
warn() { printf "\033[1;33m[WARN] %s\033[0m\n" "$*" >&2; }

{{ if not $homebrewCoreEnabled }}
echo "Skipping brew install: disabled by optional_integrations.homebrew_core"
exit 0
{{ end }}

if ! command -v brew >/dev/null 2>&1; then
  warn "Homebrew not found; skipping package installation"
  exit 0
fi

log "brew update"
brew update || warn "brew update failed; continuing"

BREWFILE="$(mktemp "${TMPDIR:-/tmp}/dotfiles-brew.XXXXXX")"
cleanup() {
  rm -f "$BREWFILE"
}
trap cleanup EXIT

cat >"$BREWFILE" <<'EOF'
{{ $brewfile }}
EOF

log "Installing declared Brewfile groups"
brew bundle install --file="$BREWFILE" || warn "brew bundle install reported failures; continuing"

# ── fzf shell integration (no rc changes — chezmoi manages zshrc) ─────────────
if [[ -x "$(brew --prefix)/opt/fzf/install" ]]; then
  "$(brew --prefix)/opt/fzf/install" --key-bindings --completion --no-update-rc >/dev/null 2>&1 || true
fi

echo ""
echo "✅ run_onchange_10: brew packages installed"
echo ""
echo "⚡ Notes:"
echo "  - source of truth: homebrew/Brewfile.*"
echo "  - cleanup is manual only: dots-brew cleanup"
echo "  - terraform and kubectl are managed by asdf (run_once_20 handles install)"
echo "  - macfuse remains manual — install from https://osxfuse.github.io"
