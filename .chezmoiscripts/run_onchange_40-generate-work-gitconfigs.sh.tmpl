{{- $cfg := includeTemplate ".chezmoitemplates/effective-config.json.tmpl" . | fromJson -}}
#!/usr/bin/env bash
# run_onchange_40-generate-work-gitconfigs.sh — Generate local work git fragments and clean legacy artifacts.
set -euo pipefail

warn() { printf "\033[1;33m[WARN] %s\033[0m\n" "$*" >&2; }
backup_root="$HOME/.local/state/dotfiles/legacy-backups"
timestamp="$(date +%Y%m%d%H%M%S)"
backup_dir="$backup_root/$timestamp"
generated_dir="$HOME/.config/dotfiles/generated/git"
removed=0

mkdir -p "$generated_dir"

backup_and_remove() {
  local path="$1"
  [[ -e "$path" ]] || return 0
  mkdir -p "$backup_dir"
  mv "$path" "$backup_dir/"
  echo "  moved legacy artifact: $path -> $backup_dir/"
  removed=$((removed + 1))
}

for path in "$HOME"/.gitconfig-work-* "$HOME"/.zshrc.d/work-*.zsh; do
  [[ -e "$path" ]] || continue
  backup_and_remove "$path"
done

generated_count=0

{{ range $slug := ($cfg.selected_work_contexts | default list) }}
{{ $ctx := index ($cfg.work_contexts | default dict) $slug | default dict }}
{{ $git := (index $ctx "git") | default dict }}
{{ $ssh := (index $ctx "ssh") | default dict }}
{{ $providers := index ((index $ctx "providers") | default dict) "enabled" | default list }}
{{ $signingKey := (index $git "signing_key") | default "" }}
{{ $signingEnabled := true }}
{{ if hasKey $git "commit_gpgsign" }}
{{ $signingEnabled = (index $git "commit_gpgsign") }}
{{ end }}
{{ $signingKeyAbs := regexReplaceAll "^~" $signingKey (env "HOME") }}
{{ $signingReady := false }}
{{ if and $signingKey $signingEnabled (stat $signingKeyAbs) }}
{{ $signingReady = true }}
{{ end }}
cat > "$generated_dir/work-{{ $slug }}.gitconfig" <<'EOF'
[user]
  name  = {{ ((index $git "name") | default ((index ($cfg.identity | default dict) "git_name") | default "Unknown User")) | quote }}
  email = {{ ((index $git "email") | default "") | quote }}
{{- if $signingReady }}
  signingkey = {{ $signingKey | quote }}
{{- else if $signingKey }}
  # signingkey intentionally omitted until {{ $signingKey }} exists and matches a 1Password SSH key item.
{{- end }}

[commit]
  gpgsign = {{ $signingReady }}

[tag]
  gpgSign = {{ $signingReady }}
{{- if has "gh" $providers }}
{{- if (index $ssh "github_alias") }}

[url "git@{{ index $ssh "github_alias" }}:"]
  insteadOf = git@github.com:
{{- end }}
{{- end }}
{{- if has "gl" $providers }}
{{- if (index $ssh "gitlab_alias") }}

[url "git@{{ index $ssh "gitlab_alias" }}:"]
  insteadOf = git@gitlab.com:
{{- end }}
{{- end }}
EOF
generated_count=$((generated_count + 1))
{{ end }}

find "$generated_dir" -type f -name 'work-*.gitconfig' | while IFS= read -r file; do
  slug="$(basename "$file" .gitconfig)"
  slug="${slug#work-}"
  case " {{ join " " ($cfg.selected_work_contexts | default list) }} " in
    *" ${slug} "*) ;;
    *) rm -f "$file"; echo "  removed stale generated git fragment: $file" ;;
  esac
done

if [[ $removed -eq 0 ]]; then
  echo "✅ run_onchange_40: no legacy work artifacts found"
else
  warn "Removed $removed legacy work artifacts; backups stored in $backup_dir"
fi

echo "✅ run_onchange_40: generated ${generated_count} local work git fragment(s)"
