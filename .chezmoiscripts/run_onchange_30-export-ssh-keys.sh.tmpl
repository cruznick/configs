#!/usr/bin/env bash
# run_onchange_30-export-ssh-keys.sh — Export SSH public keys from 1Password
{{- $cfg := includeTemplate ".chezmoitemplates/effective-config.json.tmpl" . | fromJson -}}
{{- $optional := $cfg.optional_integrations | default dict -}}
{{- $sshKeyExportEnabled := true -}}
{{- if hasKey $optional "ssh_key_export" -}}
  {{- $sshKeyExportEnabled = (index $optional "ssh_key_export") -}}
{{- end -}}
{{ if ne .chezmoi.os "darwin" -}}
echo "run_onchange_30: skipping (not macOS)"
exit 0
{{ end }}
set -euo pipefail

VAULT="{{ (index ($cfg.identity | default dict) "op_vault") | default "" }}"
PUB_DIR="$HOME/.ssh/signing-pubs"
mkdir -p "$PUB_DIR"
chmod 700 "$PUB_DIR"
warn() { printf "\033[1;33m[WARN] %s\033[0m\n" "$*" >&2; }
log() { printf "\n\033[1;34m==> %s\033[0m\n" "$*"; }

{{- if not $sshKeyExportEnabled }}
echo "run_onchange_30: skipping (ssh_key_export disabled)"
exit 0
{{- end }}

if ! command -v op >/dev/null 2>&1; then
  warn "op CLI not found; skipping SSH public key export"
  exit 0
fi

if ! op whoami >/dev/null 2>&1; then
  warn "1Password is locked; skipping SSH public key export"
  exit 0
fi

if [[ -z "$VAULT" ]]; then
  warn "identity.op_vault is not configured; attempting 1Password item lookup by title in accessible built-in vaults"
fi

exported=0
failed=0

export_key() {
  local item="$1" outfile="$2"
  local tmp
  local cmd=(op item get "$item" --fields "public key")
  outfile="${outfile/#\~/$HOME}"
  mkdir -p "$(dirname "$outfile")"
  tmp="$(mktemp)"
  if [[ -n "$VAULT" ]]; then
    cmd=(op item get "$item" --vault "$VAULT" --fields "public key")
  fi
  if ! "${cmd[@]}" > "$tmp" 2>/dev/null; then
    if [[ -n "$VAULT" ]]; then
      warn "Missing or inaccessible 1Password item: $item (vault: $VAULT)"
    else
      warn "Missing, ambiguous, or inaccessible 1Password item: $item"
      warn "Set [identity].op_vault in ~/.config/dotfiles/overrides.toml if the key lives in a shared/custom vault or item titles are ambiguous"
    fi
    rm -f "$tmp"
    failed=$((failed + 1))
    return 0
  fi
  mv "$tmp" "$outfile"
  chmod 644 "$outfile"
  echo "Exported: $outfile"
  exported=$((exported + 1))
}

log "Exporting SSH public-key selectors"

# Personal
export_key "ssh-sign-personal-gl" "$PUB_DIR/personal-gl.pub"
export_key "ssh-sign-personal-gh" "$PUB_DIR/personal-gh.pub"

# Work — local work context signing/auth items
{{ range $slug := ($cfg.selected_work_contexts | default list) -}}
{{ $ctx := index ($cfg.work_contexts | default dict) $slug | default dict -}}
{{ $git := (index $ctx "git") | default dict -}}
{{ $providers := (index $ctx "providers") | default dict -}}
{{ $defaultProvider := (index $providers "default") | default "gh" -}}
{{ $ssh := (index $ctx "ssh") | default dict -}}
{{ if (index $git "signing_item") -}}
export_key "{{ index $git "signing_item" }}" "{{ (index $git "signing_key") | default (printf "~/.ssh/signing-pubs/%s-%s.pub" $slug $defaultProvider) }}"
{{ end -}}
{{ if (index $ssh "github_agent_item") -}}
export_key "{{ index $ssh "github_agent_item" }}" "{{ (index $ssh "github_identity_file") | default (printf "~/.ssh/signing-pubs/%s-gh.pub" $slug) }}"
{{ end -}}
{{ if (index $ssh "gitlab_agent_item") -}}
export_key "{{ index $ssh "gitlab_agent_item" }}" "{{ (index $ssh "gitlab_identity_file") | default (printf "~/.ssh/signing-pubs/%s-gl.pub" $slug) }}"
{{ end -}}
{{ end -}}

echo ""
echo "✅ run_onchange_30: exported ${exported} SSH public key(s) to $PUB_DIR"
if [[ $failed -gt 0 ]]; then
  warn "${failed} key export(s) failed; SSH auth/signing selectors may be incomplete"
fi
echo ""
echo "⚡ Next steps:"
echo "  - Add $PUB_DIR/personal-gh.pub to github.com (Settings → SSH and GPG keys → Authentication + Signing)"
echo "  - Add $PUB_DIR/personal-gl.pub to gitlab.com (Preferences → SSH Keys)"
echo "  - Add work pubkeys to your work accounts (see ~/.ssh/signing-pubs/)"
if [[ -z "$VAULT" ]]; then
  echo "  - Optional but recommended: set [identity].op_vault in ~/.config/dotfiles/overrides.toml for shared/custom vaults and unambiguous exports"
fi
