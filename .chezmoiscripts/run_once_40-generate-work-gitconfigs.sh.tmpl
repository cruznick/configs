#!/usr/bin/env bash
# run_once_40-generate-work-gitconfigs.sh — Generate scoped git identity files
# Uses companies.toml (per-company email, platforms) to write per-company gitconfigs
# and ~/.zshrc.d/work-<slug>.zsh stubs.
# Runs once; re-runs automatically if this file changes (e.g. new company added).
{{ if ne .chezmoi.os "darwin" -}}
echo "run_once_40: skipping (not macOS)"
exit 0
{{ end -}}
set -euo pipefail

NAME="{{ .name }}"
PUB_DIR="$HOME/.ssh/signing-pubs"
ZSHRC_D="$HOME/.zshrc.d"
mkdir -p "$ZSHRC_D"

write_gitconfig() {
  local file="$1"
  local platform="$2"   # gl or gh
  local host_alias="$3" # e.g. github.com-acme
  local host_name="$4"  # e.g. github.com
  local email="$5"
  local key_prefix="$6" # e.g. work or company slug

  cat > "$file" <<EOF
[user]
  name       = ${NAME}
  email      = ${email}
  signingkey = ${PUB_DIR}/${key_prefix}-${platform}.pub

[url "git@${host_alias}:"]
  insteadOf = git@${host_name}:
EOF
  echo "  Written: $file"
}

write_work_zshrc() {
  local slug="$1"
  local file="$ZSHRC_D/work-${slug}.zsh"
  cat > "$file" <<'ZSHRC'
# ~/.zshrc.d/work-SLUG.zsh — SLUG company environment (non-secret config)
# Generated by chezmoi run_once_40.
#
# Company-specific SECRETS (registry tokens, proxies with credentials) belong in:
#   ~/repos/work/<platform>/SLUG/.envrc  (copy from .envrc.example, then: direnv allow)
#
# This file is for non-secret env vars: tool paths, proxy URLs without tokens, checks.

# ── Private package registry (non-secret parts) ───────────────────────────────
# export WORK_REGISTRY_URL="https://your-company.example.com/registry"
# export WORK_REGISTRY_USER="{{ .artifactoryUser }}"
#
# Example: Go proxy — token comes from direnv .envrc
# export GOPROXY="https://${WORK_REGISTRY_USER}:${WORK_REGISTRY_TOKEN:-}@company.example.com/go"
# export GONOSUMDB="gitlab.com/your-org/*"

# ── Company CLI / tooling path ─────────────────────────────────────────────────
# export PATH="$PATH:$HOME/.company-cli/bin"

# ── Tool checks ────────────────────────────────────────────────────────────────
# command -v your-tool >/dev/null || echo "⚠️  your-tool missing. brew install your-tool"
ZSHRC
  # Patch SLUG placeholder in the generated file
  sed -i '' "s/SLUG/${slug}/g" "$file"
  echo "  Written: $file"
}

GITCONFIG_COUNT=0
COMPANY_COUNT=0

{{ range $slug, $co := .companies -}}
echo "── {{ $slug }} ──────────────────────────────────────────────────────────────"
{{ if has "gl" $co.platforms -}}
write_gitconfig \
  "$HOME/.gitconfig-work-{{ $slug }}-gl" \
  "gl" \
  "gitlab.com-{{ $slug }}" \
  "gitlab.com" \
  "{{ $co.email }}" \
  "{{ default $slug $co.ssh_key_prefix }}"
GITCONFIG_COUNT=$((GITCONFIG_COUNT + 1))
{{ end -}}
{{ if has "gh" $co.platforms -}}
write_gitconfig \
  "$HOME/.gitconfig-work-{{ $slug }}-gh" \
  "gh" \
  "github.com-{{ $slug }}" \
  "github.com" \
  "{{ $co.email }}" \
  "{{ default $slug $co.ssh_key_prefix }}"
GITCONFIG_COUNT=$((GITCONFIG_COUNT + 1))
{{ end -}}
write_work_zshrc "{{ $slug }}"
COMPANY_COUNT=$((COMPANY_COUNT + 1))
{{ end -}}

echo ""
echo "✅ run_once_40: Work gitconfigs written for ${COMPANY_COUNT} companies (${GITCONFIG_COUNT} gitconfig files)"
echo ""
echo "⚡ Next steps:"
echo "  - Add ~/.ssh/signing-pubs/<key-prefix>-gh.pub to GitHub (Settings → SSH keys → Authentication + Signing)"
echo "  - Add ~/.ssh/signing-pubs/<key-prefix>-gl.pub to GitLab (Preferences → SSH Keys)"
echo "  - Authenticate glab: GLAB_CONFIG_DIR=~/.config/glab-<slug> glab auth login --hostname gitlab.com"
echo "  - Fill in ~/.secrets.zsh with global token values (GITHUB_TOKEN, etc.)"
echo "  - For each company: copy ~/repos/work/<platform>/<slug>/.envrc.example → .envrc, fill in op:// refs, run: direnv allow"
