#!/usr/bin/env bash
# run_once_05-install-fonts.sh — Copy fonts from repo to ~/Library/Fonts/
# Runs once; idempotent — skips fonts already installed.
set -euo pipefail

{{ if ne .chezmoi.os "darwin" -}}
echo "Skipping font install: not macOS"
exit 0
{{ end -}}

FONT_SRC="{{ .chezmoi.sourceDir }}/font"
FONT_DEST="$HOME/Library/Fonts"

if [[ ! -d "$FONT_SRC" ]]; then
  echo "No font/ directory found in source — skipping"
  exit 0
fi

if ! mkdir -p "$FONT_DEST"; then
  echo "Skipping font install: unable to create $FONT_DEST"
  exit 0
fi

installed=0
skipped=0

while IFS= read -r -d '' font; do
  name="$(basename "$font")"
  if [[ ! -f "$FONT_DEST/$name" ]]; then
    cp "$font" "$FONT_DEST/$name"
    echo "  installed: $name"
    (( installed++ )) || true
  else
    (( skipped++ )) || true
  fi
done < <(find "$FONT_SRC" -type f \( -name "*.ttf" -o -name "*.otf" \) -print0)

echo ""
echo "✅ run_once_05: fonts — ${installed} installed, ${skipped} already present"
