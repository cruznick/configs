# ~/.secrets.zsh — Global secrets skeleton.
# Managed by chezmoi. Edit source: dot_secrets.zsh.tmpl
#
# Fill in locally after first deploy. NEVER commit with real values.
# Company-specific secrets (registry tokens, proxies) belong in direnv:
#   ~/repos/work/<platform>/<slug>/.envrc  (copy from .envrc.example)
#
# To load: source ~/.secrets.zsh  (or open a new shell — sourced automatically)
# Requires: 1Password CLI (op) signed in. Run: op signin

# ── Personal GitHub token ──────────────────────────────────────────────────────
# Used by: gh CLI, go get private repos (if any), CI tooling
[[ -z "${GITHUB_TOKEN:-}" ]] && export GITHUB_TOKEN=""    # github.com → Settings → Developer settings → Personal access tokens

# ── Add other global tokens below ─────────────────────────────────────────────
# Format: export MY_TOKEN="$(op item get "item-name" --vault "{{ .op1pVault }}" --fields credential --reveal)"
# Only truly global tokens here; per-company tokens belong in direnv .envrc

